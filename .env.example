# ── General ──────────────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=chroma       # chroma | supabase
LLM_PROVIDER=llamacpp           # ollama | llamacpp | openai
AGENT_LANGUAGE=es               # en | es | zh
MCP_PORT=8000
AGENT_EXECUTION_MODE=confirm    # confirm | autonomous
AGENT_COMMAND_TIMEOUT_SEC=60
AGENT_COMMAND_MAX_OUTPUT=4000
AGENT_MAX_ITERATIONS=8
AGENT_MAX_TOOL_CALLS=20
AGENT_MAX_WALL_TIME_SEC=180
AGENT_TOOL_TIMEOUT_SEC=45
AGENT_POLICY_FILESYSTEM=confirm # allow | confirm | deny
AGENT_POLICY_NETWORK=allow      # allow | confirm | deny
AGENT_POLICY_PROCESS=confirm    # allow | confirm | deny
AGENT_POLICY_SYSTEM=confirm     # allow | confirm | deny
AGENT_TELEMETRY_OPT_IN=false    # true | false
TASK_ROUTER_AUTO_RECALIBRATE=false
TASK_ROUTER_RECALIBRATE_INTERVAL=100
TASK_ROUTER_MIN_SAMPLES=12
WEB_SEARCH_ENGINE=google        # google | duckduckgo | serpapi | bing | fusion | auto

# ── Agent Harness ─────────────────────────────────────────────────────────────
AGENT_HARNESS=opencode          # native | little-coder | claude-code | opencode
HARNESS_OPENCODE_BIN=           # ruta al binario opencode (auto-detecta si está en PATH)
HARNESS_CLAUDE_CODE_BIN=        # ruta al binario claude (auto-detecta si está en PATH)
HARNESS_LITTLE_CODER_DIR=       # directorio de instalación de little-coder
MINIMIZE_TO_TRAY_ON_CLOSE=false # true | false
WINDOW_CONTROLS_STYLE=windows   # windows | mac
WINDOW_CONTROLS_SIDE=right      # left | right
WINDOW_CONTROLS_ORDER=minimize,maximize,close

# ── OpenCode Harness ──────────────────────────────────────────────────────────
# Límite de contexto que OpenCode ve (independiente del contexto de llama.cpp).
# El launcher oficial usa 120000. Si lo dejás en 0, usa LLAMACPP_CONTEXT_SIZE.
OPENCODE_CONTEXT_LIMIT=120000

# MCP dentro de OpenCode. false = preserva config existente (mempalace, etc.).
OPENCODE_DISABLE_MCP=false

# Si tenés mempalace instalado, configurá el home para inyectarlo automáticamente.
# OPENCODE_MEMPALACE_HOME=C:\Users\cristian\.local\share\mempalace

# Modo mínimo de prompt (reduce tokens de entrada, mejora latencia).
OPENCODE_MINIMAL_PROMPT=true

# Saltar warmup si llama.cpp ya está corriendo.
OPENCODE_SKIP_WARMUP_IF_READY=true

# Límite de output tokens que OpenCode puede generar.
OPENCODE_OUTPUT_LIMIT=8192
OPENCODE_FIRST_CHUNK_TIMEOUT_SEC=180
OPENCODE_SILENT_TIMEOUT_SEC=900

# ── Locked Runtime (UNLZ build policy) ───────────────────────────────────────
# The app enforces these values at backend startup:
#   AGENT_HARNESS=opencode
#   AGENT_EXECUTION_MODE=autonomous
#   LLM_PROVIDER=llamacpp
#   LLAMACPP_EXECUTABLE=<bundled llama.cpp inside installer>
#
# Source of "1_*" profiles from OpenCode (developer-side authoring).
UNLZ_OPENCODE_PROFILES_FILE=C:\Users\cristian\Documents\OpenCode\launcher_profiles.json
#
# Hardware autoselect + autodescarga (editable por desarrollador, MTP-first).
# Buckets: cpu, gpu_4, gpu_8, gpu_12, gpu_16, gpu_24, gpu_32
# En gpu_24 la policy exige perfil 1_* (require_1_profile=true).
# Opcional por entrada: "sha256" para validar integridad post-descarga.
UNLZ_HARDWARE_MODEL_PLAN_JSON={"cpu":{"profile_name":"1_ GEMMA","opencode_model_id":"gemma-26b-131k","model_folder":"Qwen3.6-4B-GGUF","alias":"qwen3.6-4b-q4km","hf_repo":"unsloth/Qwen3.6-4B-GGUF","filename":"Qwen3.6-4B-Q4_K_M.gguf","fallback_candidates":[]},"gpu_4":{"profile_name":"1_ GEMMA","opencode_model_id":"gemma-26b-131k","model_folder":"Qwen3.6-8B-GGUF","alias":"qwen3.6-8b-q4km","hf_repo":"unsloth/Qwen3.6-8B-GGUF","filename":"Qwen3.6-8B-Q4_K_M.gguf","fallback_candidates":[]},"gpu_8":{"profile_name":"1_ GEMMA","opencode_model_id":"gemma-26b-131k","model_folder":"Qwen3.6-14B-GGUF","alias":"qwen3.6-14b-q4km","hf_repo":"unsloth/Qwen3.6-14B-GGUF","filename":"Qwen3.6-14B-Q4_K_M.gguf","fallback_candidates":[]},"gpu_12":{"profile_name":"1_ QWEN MTP XS","opencode_model_id":"ideal-mtp-xs-131k","model_folder":"Qwen3.6-27B-MTP-IQ4_XS-GGUF","alias":"ideal-mtp-xs-131k","hf_repo":"froggeric/Qwen3.6-27B-MTP-GGUF","filename":"Qwen3.6-27B-MTP-IQ4_XS.gguf","fallback_candidates":[{"model_folder":"Qwen3.6-27B-GGUF","alias":"qwen3.6-27b-q4km","hf_repo":"bartowski/Qwen_Qwen3.6-27B-GGUF","filename":"Qwen_Qwen3.6-27B-Q4_K_M.gguf"}],"sha256":"239372aeb0c8552dc18a895f6598e26a12c1afe457d62fef8d3a93fe99a94b1c"},"gpu_16":{"profile_name":"1_ QWEN MTP KM","opencode_model_id":"ideal-mtp-km-131k","model_folder":"Qwen3.6-27B-MTP-Q4_K_M-GGUF","alias":"ideal-mtp-km-131k","hf_repo":"RDson/Qwen3.6-27B-MTP-Q4_K_M-GGUF","filename":"Qwen3.6-27B-MTP-Q4_K_M.gguf","fallback_candidates":[{"model_folder":"Qwen3.6-27B-GGUF","alias":"qwen3.6-27b-q4km","hf_repo":"bartowski/Qwen_Qwen3.6-27B-GGUF","filename":"Qwen_Qwen3.6-27B-Q4_K_M.gguf"}],"sha256":"cf5634224deaea56c5c706d627111e6610c66f504c02680b95c861a6c6eeba6a"},"gpu_24":{"profile_name":"1_ QWEN MTP MOE","opencode_model_id":"ideal-35moe-mtp-131k","model_folder":"Qwen3.6-35B-A3B-MTP-IQ4_XS-GGUF","alias":"ideal-35moe-mtp-131k","hf_repo":"localweights/Qwen3.6-35B-A3B-MTP-IQ4_XS-GGUF","filename":"Qwen3.6-35B-A3B-MTP-IQ4_XS.gguf","require_1_profile":true,"fallback_candidates":[{"model_folder":"Qwen3.6-35B-A3B-GGUF","alias":"qwen3.6-35b-a3b-q4km","hf_repo":"cmp-nct/Qwen3.6-35B-A3B-GGUF","filename":"Qwen3.6-35B-A3B-UD-Q4_K_M.gguf","sha256":"ac0e2c1189e055faa36eff361580e79c5bd6f8e76bffb4ce547f167d53e31a61"}],"sha256":"a9d649e7735eda7e6e9501b0ae50483bbce16722f8a66867162566c7fe8bd58c"},"gpu_32":{"profile_name":"1_ QWEN MTP MOE","opencode_model_id":"ideal-35moe-mtp-131k","model_folder":"Qwen3.6-35B-A3B-MTP-IQ4_XS-GGUF","alias":"ideal-35moe-mtp-131k","hf_repo":"localweights/Qwen3.6-35B-A3B-MTP-IQ4_XS-GGUF","filename":"Qwen3.6-35B-A3B-MTP-IQ4_XS.gguf","fallback_candidates":[{"model_folder":"Qwen3.6-35B-A3B-GGUF","alias":"qwen3.6-35b-a3b-q4km","hf_repo":"cmp-nct/Qwen3.6-35B-A3B-GGUF","filename":"Qwen3.6-35B-A3B-UD-Q4_K_M.gguf","sha256":"ac0e2c1189e055faa36eff361580e79c5bd6f8e76bffb4ce547f167d53e31a61"}],"sha256":"a9d649e7735eda7e6e9501b0ae50483bbce16722f8a66867162566c7fe8bd58c"}}

# Telemetría local de selección efectiva (escritas por el backend):
# UNLZ_MODEL_SOURCE_REPO, UNLZ_MODEL_SOURCE_FILE, UNLZ_MODEL_FALLBACK_INDEX, UNLZ_MODEL_MTP_ACTIVE

# ── Advanced Mode ─────────────────────────────────────────────────────────────
# Enable advanced features: profiles, benchmarks, prompt presets,
# hardware detection, launch history, health monitoring.
UNLZ_ADVANCED_MODE=0              # true | false
LLAMACPP_MODELS_DIR=              # custom GGUF model directory (default: ~/Models/llamacpp)

# ── n8n — deshabilitado, modo directo ─────────────────────────────────────────
N8N_ENABLED=false
N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/chat

# ── llama.cpp ─────────────────────────────────────────────────────────────────
# Ejecutable (WinGet stock build)
LLAMACPP_EXECUTABLE=C:\Users\cristian\AppData\Local\Microsoft\WinGet\Packages\ggml.llamacpp_Microsoft.Winget.Source_8wekyb3d8bbwe\llama-server.exe

# Modelo activo
LLAMACPP_MODEL_PATH=C:\Users\cristian\Models\llamacpp\Qwen3.6-35B-A3B-GGUF\Qwen3.6-35B-A3B-UD-Q4_K_M.gguf
LLAMACPP_MODEL_ALIAS=qwen3.6-35b-a3b

LLAMACPP_HOST=127.0.0.1
LLAMACPP_PORT=8080
LLAMACPP_CONTEXT_SIZE=32768
LLAMACPP_N_GPU_LAYERS=999
LLAMACPP_FLASH_ATTN=true
LLAMACPP_CACHE_TYPE_K=q8_0
LLAMACPP_CACHE_TYPE_V=q8_0
LLAMACPP_EXTRA_ARGS=

# ── Alternativas disponibles ──────────────────────────────────────────────────
# Qwen3.5-35B-A3B Q4_K_M (anterior):
